<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar vista de lista para agregar campo temporada -->
    <record id="view_zapato_list_temporada" model="ir.ui.view">
        <field name="name">zapatos.zapato.list.temporada</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='precio']" position="after">
                <field name="temporada"/>
            </xpath>
        </field>
    </record>

    <!-- Heredar vista de formulario para agregar campo temporada -->
    <record id="view_zapato_form_temporada" model="ir.ui.view">
        <field name="name">zapatos.zapato.form.temporada</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group/field[@name='precio']" position="after">
                <field name="temporada"/>
            </xpath>
        </field>
    </record>
</odoo>
