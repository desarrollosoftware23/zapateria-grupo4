<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_zapato_form_inherit_layout_descuento" model="ir.ui.view">
            <field name="name">zapatos.zapato.form.inherit.layout.descuento</field>
            <field name="model">zapatos.zapato</field>
            <field name="inherit_id" ref="zapatos.view_zapato_form"/> 
            <field name="arch" type="xml">
                
                <xpath expr="//field[@name='codigo']" position="before">
                    <group>
                        <group string="Detalles Técnicos">
                            <field name="codigo"/>
                            <field name="marca"/>
                            <field name="color"/>
                            <field name="material"/>
                        </group>
                        
                        <group string="Control de Inventario y Ofertas">
                            <field name="stock_minimo"/>
                            <field name="valor_inventario" readonly="1"/>
                            <field name="porcentaje_descuento"/>
                            <field name="precio_oferta" readonly="1"/>
                        </group>
                    </group>
                </xpath>

                <xpath expr="//field[@name='marca']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='color']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='material']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='stock_minimo']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='valor_inventario']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

            </field>
        </record>

        <record id="view_zapato_list_inherit_descuento" model="ir.ui.view">
            <field name="name">zapatos.zapato.list.inherit.descuento</field>
            <field name="model">zapatos.zapato</field>
            <field name="inherit_id" ref="zapatos.view_zapato_list"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='precio']" position="after">
                    <field name="precio_oferta"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>